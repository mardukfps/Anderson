{
  "entities": {
    "OvertimeEntry": {
      "title": "Overtime Entry",
      "description": "A record of extra hours worked by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["ponto", "cartao"] },
        "date": { "type": "string", "format": "date" },
        "entryTime": { "type": "string" },
        "exitTime": { "type": "string" },
        "calculatedHours": { "type": "number" },
        "multiplier": { "type": "number" },
        "calculatedValue": { "type": "number" },
        "notes": { "type": "string" },
        "isNightShift": { "type": "boolean" },
        "nightHours": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "type", "date", "entryTime", "exitTime", "calculatedHours", "multiplier", "calculatedValue", "createdAt"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "User specific configurations for the application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "baseHourlyRate": { "type": "number" },
        "monthlyLimit": { "type": "number" },
        "defaultMultiplier": { "type": "number" },
        "theme": { "type": "string" },
        "baseSalary": { "type": "number" }
      },
      "required": ["userId", "baseHourlyRate", "monthlyLimit", "defaultMultiplier", "theme", "baseSalary"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic user information for auth consistency",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "OvertimeEntry",
      "description": "Collection of overtime entries for a specific user"
    },
    "/users/{userId}/settings/config": {
      "schema": "AppSettings",
      "description": "Configuration settings for a specific user"
    }
  }
}
