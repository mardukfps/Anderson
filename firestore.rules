rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global hardened helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Mandate email verification for all write operations
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation blueprints
    function isValidOvertimeEntry(data) {
      return data.keys().hasAll(['id', 'type', 'date', 'entryTime', 'exitTime', 'calculatedHours', 'multiplier', 'calculatedValue', 'createdAt', 'userId'])
        && data.keys().size() <= 15 // Allow for future optional fields like 'notes'
        && data.id is string && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.type in ['ponto', 'cartao']
        && data.date is string && data.date.size() == 10
        && data.calculatedHours is number
        && data.multiplier is number
        && data.calculatedValue is number
        && (data.createdAt is timestamp || data.createdAt is number);
    }

    function isValidAppSettings(data) {
      return data.keys().hasAll(['baseHourlyRate', 'monthlyLimit', 'defaultMultiplier', 'theme', 'baseSalary', 'userId'])
        && data.keys().size() == 6
        && data.userId == request.auth.uid
        && data.baseHourlyRate is number
        && data.monthlyLimit is number
        && data.defaultMultiplier is number
        && data.theme is string
        && data.baseSalary is number;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'createdAt'])
        && data.keys().size() <= 8
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.name is string && data.name.size() <= 128
        && (!data.keys().hasAny(['photoURL']) || data.photoURL == null || (data.photoURL is string))
        && (data.createdAt is timestamp || data.createdAt is number)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp || data.updatedAt is number)
        && (!data.keys().hasAny(['passwordLastChanged']) || data.passwordLastChanged is timestamp || data.passwordLastChanged is number);
    }

    // Path matches
    match /users/{userId} {
      // Profile access - strictly restricted to owner
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Allow profile creation for the authenticated user only
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      
      // Allow profile updates (name and photoURL)
      allow update: if isSignedIn() && request.auth.uid == userId 
        && isValidUser(incoming())
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'updatedAt', 'passwordLastChanged'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['photoURL', 'updatedAt'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['passwordLastChanged', 'updatedAt'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['name'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['photoURL'])
        )
        && incoming().uid == existing().uid
        && incoming().email == existing().email;

      match /entries/{entryId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        
        allow create: if isSignedIn() && request.auth.uid == userId && isVerified() 
          && isValidId(entryId) && isValidOvertimeEntry(incoming()) 
          && incoming().createdAt == request.time;
          
        allow update: if isSignedIn() && request.auth.uid == userId && isVerified() 
          && isValidOvertimeEntry(incoming())
          && incoming().id == existing().id
          && incoming().userId == existing().userId
          && incoming().createdAt == existing().createdAt
          && (
            // Action: Standard update (can change most fields)
            incoming().diff(existing()).affectedKeys().hasAny(['type', 'date', 'entryTime', 'exitTime', 'calculatedHours', 'multiplier', 'calculatedValue', 'notes', 'isNightShift', 'nightHours'])
            && !incoming().diff(existing()).affectedKeys().hasAny(['id', 'userId', 'createdAt'])
          );
          
        allow delete: if isSignedIn() && request.auth.uid == userId && isVerified();
      }

      match /settings/config {
        allow read: if isSignedIn() && request.auth.uid == userId;
        
        allow create: if isSignedIn() && request.auth.uid == userId && isVerified() && isValidAppSettings(incoming());
        
        allow update: if isSignedIn() && request.auth.uid == userId && isVerified() 
          && isValidAppSettings(incoming())
          && (
            // Action: Update config
            incoming().diff(existing()).affectedKeys().hasAny(['baseHourlyRate', 'monthlyLimit', 'defaultMultiplier', 'theme', 'baseSalary'])
            && !incoming().diff(existing()).affectedKeys().hasAny(['userId'])
          );
          
        allow delete: if false;
      }
    }
  }
}
